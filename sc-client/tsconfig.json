{
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "eslint.config.js",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
, "src/app/(website)/admissions/apply/page.tsx", "src/app/website-cms/applications/page.jsx", "src/app/dashboard/page.jsx", "src/app/fees/levies/page.jsx", "src/app/fees/outstanding/page.jsx", "src/app/login/page.jsx", "src/app/messages/page.jsx", "src/app/payroll/page.jsx", "src/app/reports/nemis/page.jsx", "src/app/settings/page.jsx", "src/app/staff/[id]/edit/page.jsx", "src/app/staff/[id]/page.jsx", "src/app/staff/page.jsx", "src/app/term-planner/page.jsx", "src/app/website-cms/contacts/page.jsx", "src/app/website-cms/gallery/page.jsx", "src/app/website-cms/homepage/page.jsx", "src/app/website-cms/news/page.jsx", "src/app/website-cms/testimonials/page.jsx", "src/app/website-cms/school-info/page.jsx", "src/app/website-cms/page.jsx", "src/components/ClassSelect.tsx", "src/components/website/sections/MissionBand.jsx", "src/components/website/sections/NoticeBoard.jsx", "src/components/website/sections/NewsGrid.jsx", "src/components/website/sections/QuickLinks.jsx", "src/components/website/sections/StatsBand.jsx", "src/components/website/sections/Hero.jsx", "src/components/website/sections/HighlightGrid.jsx"  ],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "vite/client"
    ],
    /* Bundler mode */
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    /* Linting */
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "allowJs": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "exclude": [
    "node_modules"
  ]
}
